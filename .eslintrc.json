{
  "env": {
    "browser": true,
    "es2021": true,
    "node": true,
    "cypress/globals": true
  },
  "extends": ["airbnb-base", "plugin:cypress/recommended", "plugin:prettier/recommended"],
  "plugins": ["cypress"],
  "parserOptions": {
    "ecmaVersion": 2021,
    "sourceType": "module"
  },
  "rules": {
    "import/no-extraneous-dependencies": [
      "error",
      {
        "devDependencies": true
      }
    ],
    "no-console": "off",
    "class-methods-use-this": "off"
  }
}
